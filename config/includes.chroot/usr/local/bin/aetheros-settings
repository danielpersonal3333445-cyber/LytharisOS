#!/usr/bin/env python3
import sys
import subprocess
import os
from PyQt5.QtWidgets import (QApplication, QMainWindow, QWidget, QVBoxLayout,
    QHBoxLayout, QPushButton, QLabel, QFrame, QScrollArea, QGridLayout,
    QTabWidget, QMessageBox, QSizePolicy, QFileDialog)
from PyQt5.QtCore import Qt, QTimer, QThread, pyqtSignal
from PyQt5.QtGui import QFont, QIcon, QColor, QPalette

class CommandThread(QThread):
    result = pyqtSignal(str)
    def __init__(self, cmd):
        super().__init__()
        self.cmd = cmd
    def run(self):
        try:
            out = subprocess.check_output(self.cmd, shell=True, stderr=subprocess.STDOUT, timeout=10)
            self.result.emit(out.decode().strip())
        except Exception as e:
            self.result.emit(str(e))

class StatusCard(QFrame):
    def __init__(self, title, value, color="#1D9E75"):
        super().__init__()
        self.setFrameShape(QFrame.StyledPanel)
        self.setStyleSheet(f"""
            QFrame {{
                background: palette(base);
                border: 1px solid {color};
                border-radius: 10px;
                padding: 8px;
            }}
        """)
        layout = QVBoxLayout(self)
        t = QLabel(title)
        t.setStyleSheet("color: palette(mid); font-size: 11px;")
        self.val = QLabel(value)
        self.val.setStyleSheet(f"color: {color}; font-size: 14px; font-weight: bold;")
        layout.addWidget(t)
        layout.addWidget(self.val)

    def update_value(self, v):
        self.val.setText(v)

class AetherSettings(QMainWindow):
    def __init__(self):
        super().__init__()
        self.setWindowTitle("Lytharis Control Center")
        self.setMinimumSize(900, 650)
        self.setup_ui()
        self.refresh_status()
        self.timer = QTimer()
        self.timer.timeout.connect(self.refresh_status)
        self.timer.start(5000)

    def setup_ui(self):
        central = QWidget()
        self.setCentralWidget(central)
        main_layout = QVBoxLayout(central)
        main_layout.setContentsMargins(20, 20, 20, 20)
        main_layout.setSpacing(16)

        title = QLabel("Lytharis Control Center")
        title.setStyleSheet("font-size: 22px; font-weight: bold;")
        main_layout.addWidget(title)

        tabs = QTabWidget()
        tabs.setStyleSheet("QTabBar::tab { min-width: 120px; padding: 8px; }")
        main_layout.addWidget(tabs)

        tabs.addTab(self.make_security_tab(), "Security")
        tabs.addTab(self.make_system_tab(), "System")
        tabs.addTab(self.make_network_tab(), "Network")
        tabs.addTab(self.make_settings_tab(), "Settings")
        tabs.addTab(self.make_tools_tab(), "Tools")

