    def make_settings_tab(self):
        w = QWidget()
        layout = QVBoxLayout(w)
        layout.setSpacing(12)

        layout.addWidget(QLabel("Quick Settings"))
        grid = QGridLayout()
        shortcuts = [
            ("Display", "kcmshell5 kcm_kscreen"),
            ("Audio", "kcmshell5 kcm_pulseaudio"),
            ("Bluetooth", "kcmshell5 bluedevil"),
            ("Theme", "kcmshell5 org.kde.desktop"),
            ("Icons", "kcmshell5 icons"),
            ("Fonts", "kcmshell5 fonts"),
            ("Keyboard", "kcmshell5 kcm_keyboard"),
            ("Mouse", "kcmshell5 mouse"),
            ("Touchpad", "kcmshell5 touchpad"),
            ("Power", "kcmshell5 powerdevilprofilesconfig"),
            ("Users", "kcmshell5 user_manager"),
            ("Autostart", "kcmshell5 autostart"),
            ("Notifications", "kcmshell5 notifications"),
            ("Privacy", "kcmshell5 kcm_kded"),
            ("All Settings", "systemsettings5"),
        ]
        for i, (label, cmd) in enumerate(shortcuts):
            btn = QPushButton(label)
            btn.setMinimumHeight(40)
            btn.clicked.connect(lambda _, c=cmd: subprocess.Popen(c.split()))
            grid.addWidget(btn, i // 3, i % 3)
        layout.addLayout(grid)
        layout.addStretch()
        return w

    def make_tools_tab(self):
        w = QWidget()
        layout = QVBoxLayout(w)
        layout.setSpacing(12)

        layout.addWidget(QLabel("Security Tools"))
        tools_row = QHBoxLayout()
        for label, cmd in [
            ("Metasploit", "konsole -e sudo msfconsole"),
            ("Wireshark", "wireshark"),
            ("Zenmap", "zenmap"),
            ("Partition Manager", "sudo partitionmanager"),
            ("VM Manager", "virt-manager"),
        ]:
            btn = QPushButton(label)
            btn.setMinimumHeight(40)
            btn.clicked.connect(lambda _, c=cmd: subprocess.Popen(c.split()))
            tools_row.addWidget(btn)
        layout.addLayout(tools_row)

        layout.addWidget(QLabel("Terminal"))
        term_row = QHBoxLayout()
        btn_term = QPushButton("Open Terminal")
        btn_term.clicked.connect(lambda: subprocess.Popen(["konsole"]))
        btn_root = QPushButton("Root Terminal")
        btn_root.clicked.connect(lambda: subprocess.Popen(
            ["konsole", "-e", "sudo", "zsh"]))
        term_row.addWidget(btn_term)
        term_row.addWidget(btn_root)
        layout.addLayout(term_row)

        layout.addStretch()
        return w

    def refresh_status(self):
        def check(cmd):
            try:
                subprocess.check_output(cmd, shell=True,
                    stderr=subprocess.DEVNULL)
                return True
            except:
                return False

        av = "active" if check("systemctl is-active clamav-daemon") else "inactive"
        fw = "active" if check("ufw status | grep -q active") else "inactive"
        aa = "active" if check("systemctl is-active apparmor") else "inactive"
        f2b = "active" if check("systemctl is-active fail2ban") else "inactive"
        watch = "active" if check("systemctl is-active aether-watch") else "inactive"
        maldet = "active" if check("systemctl is-active maldet") else "inactive"

        ca = "#1D9E75"
        ci = "#E24B4A"

        for card, val in [
            (self.av_card, av),
            (self.fw_card, fw),
            (self.aa_card, aa),
            (self.f2b_card, f2b),
        ]:
            card.val.setStyleSheet(
                f"color: {ca if val == 'active' else ci}; font-size: 14px; font-weight: bold;")
            card.update_value(val)

        for card, val in [
            (self.watch_card, watch),
            (self.maldet_card, maldet),
        ]:
            card.val.setStyleSheet(
                f"color: {ca if val == 'active' else ci}; font-size: 14px; font-weight: bold;")
            card.update_value(val)

        try:
            cpu = subprocess.check_output(
                "top -bn1 | grep 'Cpu(s)' | awk '{print $2+$4\"%\"}'",
                shell=True).decode().strip()
            mem = subprocess.check_output(
                "free -h | awk '/Mem/{print $3\"/\"$2}'",
                shell=True).decode().strip()
            disk = subprocess.check_output(
                "df -h / | awk 'NR==2{print $3\"/\"$2}'",
                shell=True).decode().strip()
            up = subprocess.check_output(
                "uptime -p | sed 's/up //'",
                shell=True).decode().strip()
            self.cpu_card.update_value(cpu)
            self.mem_card.update_value(mem)
            self.disk_card.update_value(disk)
            self.up_card.update_value(up)
        except:
            pass

    def show_output(self, cmd):
        try:
            out = subprocess.check_output(cmd, shell=True,
                stderr=subprocess.STDOUT, timeout=30)
            msg = QMessageBox(self)
            msg.setWindowTitle("Output")
            msg.setText(out.decode().strip()[:2000])
            msg.exec_()
        except Exception as e:
            QMessageBox.warning(self, "Error", str(e))

    def run_root_cmd(self, cmd):
        subprocess.Popen(["konsole", "-e", "bash", "-c",
            f"sudo {cmd}; echo; echo Done. Press Enter to close.; read"])

    def confirm_then_run(self, question, cmd):
        reply = QMessageBox.question(self, "Confirm", question,
            QMessageBox.Yes | QMessageBox.No)
        if reply == QMessageBox.Yes:
            self.run_root_cmd(cmd)

    def dual_scan_file(self):
        file, _ = QFileDialog.getOpenFileName(self, "Select file to scan")
        if file:
            self.run_root_cmd(f"aether-scan '{file}'")

if __name__ == "__main__":
    app = QApplication(sys.argv)
    app.setApplicationName("Lytharis Control Center")
    win = AetherSettings()
    win.show()
    sys.exit(app.exec_())
