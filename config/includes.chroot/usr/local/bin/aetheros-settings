        btn_dual.clicked.connect(self.dual_scan_file)
        btn_dual_home = QPushButton("Scan Entire Home")
        btn_dual_home.clicked.connect(lambda: self.run_root_cmd(
            "clamscan -r /home --bell -i"))
        btn_quarantine = QPushButton("View Quarantine")
        btn_quarantine.clicked.connect(lambda: self.show_output(
            "ls -lah /var/quarantine/"))
        btn_av_log = QPushButton("AV Scan Log")
        btn_av_log.clicked.connect(lambda: self.show_output(
            "tail -100 /var/log/aetheros-av.log"))
        btn_watcher = QPushButton("Watcher Log")
        btn_watcher.clicked.connect(lambda: self.show_output(
            "tail -50 /var/log/aetheros-watch.log"))
        dual_row.addWidget(btn_dual)
        dual_row.addWidget(btn_dual_home)
        dual_row.addWidget(btn_quarantine)
        dual_row.addWidget(btn_av_log)
        dual_row.addWidget(btn_watcher)
        layout.addLayout(dual_row)

        layout.addWidget(QLabel("Firewall Control (requires root)"))
        fw_row = QHBoxLayout()
