            "freshclam && maldet --update"))
        btn_watch_on = QPushButton("Enable Watcher")
        btn_watch_on.clicked.connect(lambda: self.run_root_cmd(
            "systemctl start aether-watch"))
        btn_watch_off = QPushButton("Disable Watcher")
        btn_watch_off.clicked.connect(lambda: self.confirm_then_run(
            "Disable real-time watcher?", "systemctl stop aether-watch"))
        av_row.addWidget(btn_av_on)
        av_row.addWidget(btn_av_off)
        av_row.addWidget(btn_scan)
        av_row.addWidget(btn_update_sigs)
        av_row.addWidget(btn_watch_on)
        av_row.addWidget(btn_watch_off)
        layout.addLayout(av_row)

        layout.addWidget(QLabel("Dual-AV Scanner (ClamAV + Maldet + YARA)"))
