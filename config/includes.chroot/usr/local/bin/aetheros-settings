            "ufw status verbose"))
        fw_row.addWidget(btn_fw_on)
        fw_row.addWidget(btn_fw_off)
        fw_row.addWidget(btn_fw_status)
        layout.addLayout(fw_row)

        layout.addWidget(QLabel("Security Scans"))
        scan_row = QHBoxLayout()
        btn_rk = QPushButton("Rootkit Scan")
        btn_rk.clicked.connect(lambda: self.run_root_cmd(
            "rkhunter --check --skip-keypress"))
        btn_audit = QPushButton("View Audit Log")
        btn_audit.clicked.connect(lambda: self.show_output(
